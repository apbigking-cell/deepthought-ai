# DeepSeek V4 Pro API
DEEPSEEK_API_KEY=sk-your-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# QQ官方机器人
QQ_BOT_APP_ID=your-app-id
QQ_BOT_CLIENT_SECRET=your-client-secret
QQ_DEFAULT_USER_ID=

# 微信 iLink Bot（扫码登录获取token）
WEIXIN_BOT_TOKEN=

# 所在地区
LOCATION_CITY=杭州
LOCATION_REGION=华东
LOCATION_COUNTRY=中国
LOCATION_TIMEZONE=Asia/Shanghai

# MCP服务器（按编号添加，可为空）
# MCP_SERVER_1_NAME=filesystem
# MCP_SERVER_1_COMMAND=npx
# MCP_SERVER_1_ARGS=-y @modelcontextprotocol/server-filesystem /tmp
MCP_AUTO_CONNECT=false

# 终端权限（true=工作型人格可直接跑shell命令；false=危险命令需人工批准）
# TERMINAL_ALLOW_EXEC=true

# 心跳配置
HEARTBEAT_INTERVAL_MS=1000
MICRO_SLEEP_INTERVAL_TICKS=3600
MICRO_SLEEP_DURATION_MS=5000

# 认知循环（实时思考 / 意识流 / 自主工作）
COGNITION_THINK_MS=45000          # 空闲时自发思考的最小间隔
COGNITION_MIN_THINK_MS=12000      # 高唤醒/有待办时的加速下限
WORK_MAX_ROUNDS=6                 # 单次心跳工作循环最大工具轮数
WORK_BUDGET_MS=60000              # 单次工作时间盒
# PERSONA_WORKSPACE_ROOT=          # 人格自主工作沙箱根目录(默认 ./workspace)

# 上下文分档（控成本核心）——按人格自主模式自动选择
# chat 档（陪伴/闲聊人格）：精简上下文 + 低推理，频繁思考也便宜
COGNITION_CHAT_CHARS=6000         # 上下文字符预算
COGNITION_CHAT_EPISODIC=8         # 喂入近期经历条数
COGNITION_CHAT_THOUGHTS=10        # 回喂意识流条数
COGNITION_CHAT_RELEVANT=4         # 相关记忆条数
COGNITION_CHAT_REASONING=low      # 推理强度 low/medium/high/max
COGNITION_CHAT_MAXTOKENS=1536     # 输出上限
# work 档（编程/工作人格）：放开到接近 1M 大窗口 + 高推理
COGNITION_WORK_CHARS=600000       # 上下文字符预算(中文约≈36万token，可上调接近1M)
COGNITION_WORK_EPISODIC=60        # 喂入近期经历条数
COGNITION_WORK_THOUGHTS=40        # 回喂意识流条数
COGNITION_WORK_RELEVANT=8         # 相关记忆条数
COGNITION_WORK_REASONING=high     # 推理强度
COGNITION_WORK_MAXTOKENS=4096     # 输出上限(写代码需要较大)

# 代码依赖图谱 CodeMap（分层可缩放，强化编程能力）
# 构建参数：控制各层 md 文件大小，保证 DeepSeek 读取轻量
CODEMAP_SMALL_MAX_FILES=12        # 文件数<=此值不展开模块层(仅 index+files)
CODEMAP_MAX_EDGES=40              # 单文件方法级调用连线上限
CODEMAP_MAX_METHODS=60            # 单文件列出方法上限
CODEMAP_SUMMARY=false             # 是否生成 LLM 摘要(默认关，省成本)
# 上下文 Agent：逐层放大取上下文的预算(控 token)
CODEMAP_CTX_MAX_MODULES=6         # 单次最多放大的模块数
CODEMAP_CTX_MAX_FILES=8           # 单次最多放大的文件数
CODEMAP_CTX_FILE_MD=2000          # 单文件依赖区块字符预算
CODEMAP_CTX_FILE_CODE=2400        # 单文件真实代码字符预算
CODEMAP_CTX_TOTAL=60000           # 单次取上下文总字符预算
CODEMAP_CTX_CODE_LINES=4          # 方法片段额外上下文行数
